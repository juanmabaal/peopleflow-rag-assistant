# ============================================================

# PeopleFlow RAG Assistant - Environment Variables Example

# ============================================================

# Copy this file as .env and fill in your real credentials.

# Never commit your real .env file.

# ============================================================

# ============================================================

# LLM Provider Selector

# Options:

# - openai

# - xai

# - deepseek

# ============================================================

LLM_PROVIDER=openai

# ============================================================

# OpenAI

# Required if:

# - LLM_PROVIDER=openai

# - EMBEDDING_PROVIDER=openai

# ============================================================

OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4o-mini

# ============================================================

# xAI / Grok

# Required if LLM_PROVIDER=xai

# Use the model available in your xAI account.

# ============================================================

XAI_API_KEY=your_xai_api_key_here
XAI_MODEL=grok-4.3

# ============================================================

# DeepSeek

# Required if LLM_PROVIDER=deepseek

# Use the model available in your DeepSeek account.

# ============================================================

DEEPSEEK_API_KEY=your_deepseek_api_key_here
DEEPSEEK_MODEL=deepseek-chat

# ============================================================

# Embeddings

# Important:

# If you change the embedding model, you may need to recreate

# your Pinecone indexes because vector dimensions can change.

# ============================================================

EMBEDDING_PROVIDER=openai
EMBEDDING_MODEL=text-embedding-3-small

# ============================================================

# Pinecone

# Create both indexes before running ingestion scripts.

#

# Recommended configuration for text-embedding-3-small:

# dimension: 1536

# metric: cosine

# ============================================================

PINECONE_API_KEY=your_pinecone_api_key_here

PINECONE_INDEX_NAME_INTERNAL=peopleflow-hr-docs
PINECONE_INDEX_NAME_WEB=peopleflow-hr-web-refs

# ============================================================

# LangSmith / LangChain Tracing

# Required only if you want observability and tracing.

# ============================================================

LANGCHAIN_API_KEY=your_langsmith_api_key_here
LANGCHAIN_TRACING_V2=true
LANGCHAIN_PROJECT=peopleflow-rag-assistant

# ============================================================

# Tavily

# Required for curated web ingestion.

# ============================================================

TAVILY_API_KEY=your_tavily_api_key_here
